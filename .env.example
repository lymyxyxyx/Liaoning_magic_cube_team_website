APP_URL=https://lncubing.com

# Auth secret for signing session tokens (generate with: openssl rand -hex 32)
AUTH_SECRET=change-me-to-a-random-secret

# PostgreSQL
POSTGRES_DB=ln_cubing
POSTGRES_USER=ln_cubing
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://ln_cubing:change-me@postgres:5432/ln_cubing
# PostgreSQL connection pool tuning for the web container
PG_POOL_MAX=10
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000

# Admin passwords
ADMIN_PASSWORD=change-me
# Optional separate password for editing judges; falls back to ADMIN_PASSWORD.
JUDGE_ADMIN_PASSWORD=change-me
WEEKLY_ADMIN_PASSWORD=change-me
# Set to true when Nginx is the only public entry point; enables IP-based
# in-memory fallback rate limits for public write APIs.
PUBLIC_WRITE_TRUST_PROXY=true
# Keep public weekly competition pages and APIs hidden until launch.
WEEKLY_COMPETITION_ENABLED=false
# Required for public weekly competition access. Keep this only in the server environment.
WEEKLY_INVITE_CODE=change-me-to-a-private-invite-code

# WCA import paths inside the web container
WCA_DATA_ROOT=/app/data
WCA_LOG_DIR=/app/logs
# Optional overrides — defaults are derived from WCA_DATA_ROOT if not set
# WCA_RAW_DIR=/app/data/wca_raw
# WCA_TMP_DIR=/app/data/wca_tmp
# WCA_STATE_DIR=/app/data/wca_state
